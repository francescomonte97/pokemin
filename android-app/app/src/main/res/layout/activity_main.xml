<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pokemin_background">

    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never" />

    <TextView
        android:id="@+id/native_back_button"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/native_back_button"
        android:elevation="2dp"
        android:gravity="center"
        android:minWidth="66dp"
        android:paddingStart="9dp"
        android:paddingEnd="9dp"
        android:text="@string/back"
        android:textColor="#E6FFFFFF"
        android:textSize="9sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/native_run_toolbar"
        android:layout_width="46dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/native_panel"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/native_cup_button"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/native_button"
            android:contentDescription="@string/cup"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/native_cup" />

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="42dp"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/native_pokedex_button"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/native_button"
                android:contentDescription="@string/pokedex"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/native_pokedex" />

            <TextView
                android:id="@+id/native_pokedex_loading"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_gravity="bottom"
                android:contentDescription="@string/loading"
                android:gravity="center"
                android:textColor="#FFFFD84A"
                android:textSize="9sp"
                android:visibility="gone" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/native_settings_button"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/native_button"
            android:contentDescription="@string/settings"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/native_settings" />

        <TextView
            android:id="@+id/native_rerun_button"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/native_button"
            android:contentDescription="@string/rerun"
            android:gravity="center"
            android:text="↻"
            android:textColor="#FFFFFFFF"
            android:textSize="23sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/native_loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/pokemin_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/native_loading_pokeball"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher" />
    </LinearLayout>
</FrameLayout>
